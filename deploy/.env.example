# Copy to .env and edit. docker-compose reads this automatically.

# Access token for a PRIVATE/full instance (users paste it in the browser
# once). Generate: openssl rand -hex 24
# Leave EMPTY for the public demo — demo mode is open but guard-railed
# (5 slides per deck, 3 videos per hour per IP).
SLIDESTREAM_TOKEN=

# Port to expose on the host (put nginx/Caddy in front for TLS on
# app.slidestream.eduserver.au).
PORT=8080

# --- hosted-demo banner -----------------------------------------------------
# true on your public VPS: shows "install locally for full control over LLM,
# image and video generation". Set false for a private/full instance.
SLIDESTREAM_DEMO=true

# Prebuilt image tag to pull (latest, or a version like 2.7.0).
SLIDESTREAM_IMAGE_TAG=latest

# 1 (default in docker-compose) = the server sits behind a reverse proxy and
# may trust the proxy-appended X-Forwarded-For entry for the per-IP demo rate
# limit. Set 0 if clients reach the container port directly, otherwise the
# header is client-supplied and spoofable.
SLIDESTREAM_TRUSTED_PROXY=1

# Housekeeping knobs (defaults shown). Job workdirs are deleted after this
# many minutes; uploads over these sizes are rejected with 413.
# SLIDESTREAM_JOB_TTL_MIN=60
# SLIDESTREAM_MAX_DECK_MB=30
# SLIDESTREAM_MAX_VOICE_MB=30
# SLIDESTREAM_MAX_PHOTO_MB=15

# --- provider keys for the "free"/hosted tools ------------------------------
# Only what your slidestream.yaml actually references is needed. Cheap/free
# defaults for a demo: Gemini for narration + Imagen images (~$0.02/image),
# gTTS (free voice).
# LLM (narration writer) key by provider: gemini->GEMINI_API_KEY,
# openai->OPENAI_API_KEY, claude->ANTHROPIC_API_KEY, groq->GROQ_API_KEY.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=
# Bearer tokens for your self-hosted services (only what slidestream.yaml uses).
CHATTERBOX_TOKEN=      # voice cloning server
VOICEBOX_TOKEN=        # Voicebox studio, if used (profile_id or ephemeral clone)
SWARMUI_TOKEN=         # SwarmUI image server
COMFYUI_TOKEN=         # ComfyUI (SadTalker/Wav2Lip avatars)
