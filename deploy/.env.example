# Copy to .env and edit. docker-compose reads this automatically.

# --- required ---------------------------------------------------------------
# Access token for the web UI (users paste it in the browser once). Generate:
#   openssl rand -hex 24
SLIDESTREAM_TOKEN=change-me

# Port to expose on the host (put nginx/Caddy in front for TLS on
# app.slidestream.eduserver.au).
PORT=8080

# --- hosted-demo banner -----------------------------------------------------
# true on your public VPS: shows "install locally for full control over LLM,
# image and video generation". Set false for a private/full instance.
SLIDESTREAM_DEMO=true

# Pin a released version for a reproducible image (optional).
SLIDE_STREAM_VERSION=

# --- provider keys for the "free"/hosted tools ------------------------------
# Only what your slidestream.yaml actually references is needed. Cheap/free
# defaults for a demo: Gemini Imagen (~$0.02/image), gTTS (free voice).
GEMINI_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# Bearer token for your self-hosted Chatterbox voice server, if used.
CHATTERBOX_TOKEN=
