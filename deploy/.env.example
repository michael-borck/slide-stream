# Copy to .env and edit. docker-compose reads this automatically.

# --- required ---------------------------------------------------------------
# Access token for the web UI (users paste it in the browser once). Generate:
#   openssl rand -hex 24
SLIDESTREAM_TOKEN=change-me

# Port to expose on the host (put nginx/Caddy in front for TLS on
# app.slidestream.eduserver.au).
PORT=8080

# --- hosted-demo banner -----------------------------------------------------
# true on your public VPS: shows "install locally for full control over LLM,
# image and video generation". Set false for a private/full instance.
SLIDESTREAM_DEMO=true

# Prebuilt image tag to pull (latest, or a version like 2.7.0).
SLIDESTREAM_IMAGE_TAG=latest

# --- provider keys for the "free"/hosted tools ------------------------------
# Only what your slidestream.yaml actually references is needed. Cheap/free
# defaults for a demo: Gemini for narration + Imagen images (~$0.02/image),
# gTTS (free voice).
# LLM (narration writer) key by provider: gemini->GEMINI_API_KEY,
# openai->OPENAI_API_KEY, claude->ANTHROPIC_API_KEY, groq->GROQ_API_KEY.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=
# Bearer tokens for your self-hosted services (only what slidestream.yaml uses).
CHATTERBOX_TOKEN=      # voice cloning server
VOICEBOX_TOKEN=        # Voicebox studio, if used
SWARMUI_TOKEN=         # SwarmUI image server
COMFYUI_TOKEN=         # ComfyUI (SadTalker/Wav2Lip avatars)
